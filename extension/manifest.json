{
  "manifest_version": 3,
  "name": "Ed Tutor Assistant",
  "version": "1.0",
  "description": "Suggests answers to student questions on Ed Discussion using past Q&A records.",
  "permissions": ["activeTab", "storage", "tabs"],
  "background": { "service_worker": "background.js" },
  "host_permissions": [
    "https://edstem.org/*",
    "http://localhost:8765/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://edstem.org/*"],
      "js": ["content.js"],
      "css": ["sidebar.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Ed Tutor Assistant"
  },
  "options_page": "options.html"
}
